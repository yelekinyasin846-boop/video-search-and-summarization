# =============================================================================
# DEV-PROFILE-LVS ENVIRONMENT CONFIGURATION
# =============================================================================
# This file contains environment variables for the developer LVS profile.
# Services: Foundational, VST, NIM, LVS, Agents
#
# Profile variants:
# 2d:
#   bp_developer_lvs
# =============================================================================

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================
# These variables control which services are deployed
# User should modify these based on deployment requirements

# Deployment mode: 2d
MODE=2d

# Blueprint profile: bp_developer_lvs
BP_PROFILE=bp_developer_lvs

# Hardware profile for NIM configuration optimization
# Valid values: H100, L40S, RTXPRO6000BW, DGX-SPARK, IGX-THOR, AGX-THOR, OTHER
HARDWARE_PROFILE=H100

RESERVED_DEVICE_IDS=''
FIXED_SHARED_DEVICE_IDS=''
LLM_DEVICE_ID='0'
VLM_DEVICE_ID='0'

# LLM_MODE and VLM_MODE for deployment: local_shared, local, or remote
# For local_shared: requires NGC_CLI_API_KEY, runs LLM and VLM on single GPU
# For local: requires NGC_CLI_API_KEY
# For remote: requires LLM_BASE_URL and VLM_BASE_URL to be configured
LLM_MODE=local_shared
VLM_MODE=local_shared

# LLM options:
# - LLM_NAME: nvidia/nvidia-nemotron-nano-9b-v2
#   LLM_NAME_SLUG: nvidia-nemotron-nano-9b-v2
# - LLM_NAME: nvidia/NVIDIA-Nemotron-Nano-9B-v2-FP8
#   LLM_NAME_SLUG: nvidia-nemotron-nano-9b-v2-fp8
# - LLM_NAME: nvidia/nemotron-3-nano
#   LLM_NAME_SLUG: nemotron-3-nano
# - LLM_NAME: nvidia/llama-3.3-nemotron-super-49b-v1.5
#   LLM_NAME_SLUG: llama-3.3-nemotron-super-49b-v1.5
# - LLM_NAME: openai/gpt-oss-20b
#   LLM_NAME_SLUG: gpt-oss-20b
LLM_NAME=nvidia/nvidia-nemotron-nano-9b-v2
LLM_NAME_SLUG=nvidia-nemotron-nano-9b-v2
LLM_ENV_FILE=''
LLM_BASE_URL=''
LLM_MODEL_TYPE=nim

# VLM is served by the RT-VLM container in the LVS profile. For local and
# local_shared deployments, RT-VLM loads the integrated NGC checkpoint below
# instead of a separate Cosmos NIM container.
VLM_NAME=nim_nvidia_cosmos-reason2-8b_hf-1208
# Use the following VLM_NAME for Nemotron Nano Omni
#VLM_NAME=Nemotron-Nano-V3-Omni-GA0420-FP8
VLM_NAME_SLUG=none
VLM_ENV_FILE=''
VLM_BASE_URL=''
VLM_MODEL_TYPE=rtvi

# Computed compose profiles (DO NOT MODIFY)
COMPOSE_PROFILES=${BP_PROFILE}_${MODE},llm_${LLM_MODE}_${LLM_NAME_SLUG}

# =============================================================================
# CORE INFRASTRUCTURE PATHS
# =============================================================================
# Used by: Foundational services, VST, NIM, LVS, Agents
# User MUST modify these paths

# Path to deployments directory
VSS_APPS_DIR="/path/to/deploy/docker"

# Path to data directory (for models, videos, data logs)
VSS_DATA_DIR="/path/to/vss-apps-data"

# Host IP address for networking
HOST_IP='<HOST_IP>'
EXTERNAL_IP="${HOST_IP}"

# HAProxy ingress
HAPROXY_PORT=7777
VSS_PUBLIC_HTTP_PROTOCOL=http
VSS_PUBLIC_WS_PROTOCOL=ws
VSS_PUBLIC_HOST=${EXTERNAL_IP}
VSS_PUBLIC_PORT=${HAPROXY_PORT}

# =============================================================================
# API KEYS & CREDENTIALS
# =============================================================================

# NGC CLI API Key (REQUIRED for local LLM / VLM deployment)
# Obtain from: https://ngc.nvidia.com/
NGC_CLI_API_KEY=''

# NVIDIA API Key (REQUIRED for build.nvidia.com remote LLM / VLM endpoints)
# Obtain from: https://build.nvidia.com/
NVIDIA_API_KEY=''

# OPENAI API Key (REQUIRED for openai remote LLM / VLM endpoints)
# Obtain from: https://platform.openai.com/
OPENAI_API_KEY=''

# =============================================================================
# ELASTICSEARCH CONFIGURATION
# =============================================================================

# Elasticsearch ILM policy retention period
ELASTICSEARCH_ILM_MIN_AGE=4h

# Maximum number of attempts to connect to Elasticsearch
ELASTICSEARCH_CONNECTION_MAX_ATTEMPTS=20

# =============================================================================
# MESSAGE BROKER CONFIGURATION
# =============================================================================
# Used by: Foundational services, VST

# Message broker type: kafka or redis
STREAM_TYPE=kafka

# =============================================================================
# NVSTREAMER CONFIGURATION
# =============================================================================
# Used by: developer-profiles/dev-profile-lvs/compose.yml nvstreamer-lvs

# Install additional packages for audio, software encoding, file upload
NVSTREAMER_INSTALL_ADDITIONAL_PACKAGES=true

# Nvstreamer HTTP port
NVSTREAMER_HTTP_PORT=31000

# =============================================================================
# DOCKER COMPOSE CONFIGURATION
# =============================================================================

# Project name for volume naming (DO NOT MODIFY)
COMPOSE_PROJECT_NAME=mdx

# =============================================================================
# NIM CONFIGURATION
# =============================================================================
# Used by: vss-agent

# LLM Configuration
LLM_PORT=30081

# VLM Configuration
VLM_PORT=8018

VLM_NIM_KVCACHE_PERCENT="0.7"
# Custom model weights (optional)
# VLM_CUSTOM_WEIGHTS=""

# Evaluation LLM Judge
EVAL_LLM_JUDGE_NAME=${LLM_NAME}
EVAL_LLM_JUDGE_BASE_URL=${LLM_BASE_URL}

# =============================================================================
# VSS AGENT CONFIGURATION
# =============================================================================
# Used by: vss-agent, vss-ui services

# VSS Agent Core
VSS_AGENT_VERSION=3.2.0-26.05.2-67b165b4bfbd
VSS_AGENT_CONFIG_FILE=./deploy/docker/developer-profiles/dev-profile-lvs/vss-agent/configs/config.yml
VSS_AGENT_HOST=0.0.0.0
VSS_AGENT_PORT=8000
# Nemotron Nano Omni: set true for VST/LVS audio path (see vss-agent config enable_audio). Optional Omni block below.
ENABLE_AUDIO=false

# LVS Backend URL
LVS_BACKEND_URL=http://${HOST_IP}:38111

# =============================================================================
# RTVI CONFIGURATION
# =============================================================================
# Used by: RTVI services, LVS backend

# RTVI VLM Container Image tags for x86 and THOR
RTVI_VLM_IMAGE_TAG="3.2.0-26.05.1"

# Uncomment below RTVI VLM Container Image tag for DGX-SPARK
#RTVI_VLM_IMAGE_TAG="3.2.0-26.05.1-sbsa"

RTVI_VLM_PORT=8018
RTVI_VLM_BASE_URL=http://${HOST_IP}:8018
RTVI_VLM_ENDPOINT=''

RTVI_VLM_URL=http://${HOST_IP}:${RTVI_VLM_PORT}
RTVI_VLLM_GPU_MEMORY_UTILIZATION=''
RTVI_VLM_MODEL_TO_USE=cosmos-reason2
RTVI_VLM_MODEL_PATH='ngc:nim/nvidia/cosmos-reason2-8b:hf-1208'

# -----------------------------------------------------------------------------
# Optional: Configuration for Nemotron Nano Omni
# Uncomment below and set HF_TOKEN
# -----------------------------------------------------------------------------
#RTVI_VLM_MODEL_TO_USE=vllm-compatible
#RTVI_VLM_MODEL_PATH='git:https://huggingface.co/nvidia/Nemotron-Nano-V3-Omni-GA0420-FP8'
#VLM_MODEL_SUPPORTS_AUDIO=true
#VLM_TRUST_REMOTE_CODE=true
#INSTALL_PROPRIETARY_CODECS=true
#HF_TOKEN=<your_hf_token>
# Also set ENABLE_AUDIO=true in the VSS Agent section above when using Omni.

# RTVI VLM Kafka Configuration
RTVI_VLM_KAFKA_ENABLED=true
# Raw VLM event topic produced by rtvi-vlm and consumed by the shared
# infra Logstash LVS pipeline.
RTVI_VLM_KAFKA_TOPIC=mdx-vlm-captions
RTVI_VLM_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
RTVI_VLM_KAFKA_INCIDENT_TOPIC=mdx-vlm-incidents

# =============================================================================
# VST (VIDEO STORAGE TOOL) CONFIGURATION
# =============================================================================
# Used by: vss-agent, vss-ui

# VST Base Configuration
VST_PORT=30888
VST_EXTERNAL_URL=${VSS_PUBLIC_HTTP_PROTOCOL}://${VSS_PUBLIC_HOST}:${VSS_PUBLIC_PORT}
VST_INTERNAL_URL=http://${HOST_IP}:${VST_PORT}

# VST Image tags for common all platforms
VST_STREAM_PROCESSOR_IMAGE_TAG="2.1.0-26.05.1"
VST_SENSOR_IMAGE_TAG="2.1.0-26.05.1"
NVSTREAMER_IMAGE_TAG="2.1.0-26.05.1"
VST_INGRESS_IMAGE_TAG="2.1.0-26.05.1.1"

# =============================================================================
# AGENT STORAGE & REPORT CONFIGURATION
# =============================================================================
# Used by: vss-agent

# Object store type: local_object_store (in-memory, not persisted) or s3
VSS_AGENT_OBJECT_STORE_TYPE=local_object_store

# Base URL for report access
VSS_AGENT_REPORTS_BASE_URL=${VSS_PUBLIC_HTTP_PROTOCOL}://${VSS_PUBLIC_HOST}:${VSS_PUBLIC_PORT}/static/
VSS_AGENT_EXTERNAL_URL=${VSS_PUBLIC_HTTP_PROTOCOL}://${VSS_PUBLIC_HOST}:${VSS_PUBLIC_PORT}

# =============================================================================
# PHOENIX TELEMETRY CONFIGURATION
# =============================================================================
# Used by: vss-agent

PHOENIX_ENDPOINT=http://${HOST_IP}:6006

# =============================================================================
# AGENT UI CONFIGURATION
# =============================================================================
# Used by: vss-ui

NEXT_PUBLIC_APP_TITLE="VSS BLUEPRINT"
NEXT_PUBLIC_APP_SUBTITLE="Vision (LVS)"
NEXT_PUBLIC_ENABLE_CHAT_TAB=false
NEXT_PUBLIC_ENABLE_CHAT_SIDEBAR=true
NEXT_PUBLIC_SIDEBAR_CHAT_WORKFLOW="VSS Agent"
NEXT_PUBLIC_SIDEBAR_CHAT_CHAT_API_CUSTOM_AGENT_PARAMS_JSON={"params":[{"name":"llm_reasoning","label":"LLM Reasoning","type":"boolean","default-value":false,"changeable":true,"tooltip-info":""},{"name":"vlm_reasoning","label":"VLM Reasoning","type":"boolean","default-value":false,"changeable":true,"tooltip-info":""}]}
NEXT_PUBLIC_SIDEBAR_CHAT_CHAT_UPLOAD_FILE_ENABLE=true
NEXT_PUBLIC_SIDEBAR_CHAT_WEB_SOCKET_DEFAULT_ON=true
NEXT_PUBLIC_ENABLE_ALERTS_TAB=false
NEXT_PUBLIC_ENABLE_SEARCH_TAB=false
NEXT_PUBLIC_ENABLE_DASHBOARD_TAB=true
NEXT_PUBLIC_ENABLE_MAP_TAB=false
NEXT_PUBLIC_ENABLE_VIDEO_MANAGEMENT_TAB=true
NEXT_PUBLIC_VIDEO_MANAGEMENT_VIDEO_UPLOAD_ENABLE=true
NEXT_PUBLIC_VIDEO_MANAGEMENT_TAB_ADD_RTSP_ENABLE=true
# =============================================================================
# LVS (LONG VIDEO SUMMARIZATION) CONFIGURATION
# =============================================================================
# Used by: LVS service

# LVS Image name
LVS_IMAGE="nvcr.io/nvstaging/vss-core/vss-video-summarization"

# LVS Image tags for x86 and DGX-THOR
LVS_TAG="3.2.0-rc11-d65196a"

# Uncomment below LVS Image tags for DGX-SPARK
# LVS_TAG="3.2.0-rc11-d65196a-arm64-sbsa"

# Kafka integration: route LVS structured summaries through Kafka
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=${HOST_IP}:9092
KAFKA_STRUCTURED_SUMMARY_TOPIC=mdx-structured-events-summary
LVS_ENABLE_LLM_MERGING=true

# LVS MCP/SSE endpoint is optional for the developer profile; the agent uses
# the backend HTTP API. Enable only when an external MCP client needs it.
LVS_ENABLE_MCP=false
