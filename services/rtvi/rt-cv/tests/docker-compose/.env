# Copy to .env and adjust for your host.
#
# Kafka: bitnami/kafka is no longer on public Docker Hub; use apache/kafka instead.
# Set to a tag you already have locally to avoid pulls (e.g. apache/kafka:4.1.1).
KAFKA_IMAGE=apache/kafka:3.9.0

# If `docker compose up` fails with HTTP 429, pull when the registry allows or use a
# local build:  cd ../.. && docker build -f docker/x86.Dockerfile -t rtvi-cv:3.2.0-custom-x86 .
# then set RTVI_CV_IMAGE=rtvi-cv:3.2.0-custom-x86 (compose uses pull_policy: if_not_present).
#
# Pre-built NGC image (ngc registry login). On x86 use linux/amd64 so Docker does not
# select an arm64 manifest.
RTVI_CV_IMAGE=nvcr.io/nvstaging/vss-core/vss-rt-cv:3.2.0-26.05.1
RTVI_CV_PLATFORM=linux/amd64

# GPU index passed to the RT-CV container
NVIDIA_VISIBLE_DEVICES=0

# Kafka topic used by DeepStream msg broker (must match source_nvmultiurisrcbin_kafka.compose.txt)
KAFKA_TOPIC=ds-perception

# REST API (host side, after compose up)
REST_URL=http://localhost:9000

# test-scripts/ (see ../test-scripts/run-all-tests.sh)
CONSUME_TIMEOUT_SEC=90
MIN_MESSAGES=1
PIPELINE_WARMUP_SEC=45
REST_TIMEOUT_SEC=300
TEST_CAMERA_ID=camera_0
TEST_STREAM_FILE=sample_1080p_h264.mp4
