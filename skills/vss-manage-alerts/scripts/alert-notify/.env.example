# Which notification backends to enable (comma-separated).
# Options: slack, dashboard
NOTIFY_BACKENDS=dashboard

# --- Slack backend ---
SLACK_BOT_TOKEN=xoxb-YOUR-SLACK-BOT-TOKEN
SLACK_CHANNEL_ID=C0YOUR_CHANNEL_ID

# --- Dashboard backend (WebSocket RPC via chat.inject) ---
# Token from gateway.auth.token in ~/.openclaw/openclaw.json
OPENCLAW_GATEWAY_AUTH_TOKEN=
# Gateway HTTP URL (ws:// derived automatically)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# --- Shared ---
# VST host:port (no scheme)
VST_ENDPOINT=10.57.233.252:30888
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=9090
